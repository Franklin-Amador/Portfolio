---
const { title, titleEN, img, content, contentES, contentEN, href } = Astro.props;
const isLink = Boolean(href);
---
{
	isLink ? (
		<a href={href} class="blog-card">
			<div class="blog-card__media">
				<img alt={title} src={img} loading="lazy" />
			</div>
			<div class="blog-card__body">
				<h3 class="blog-card__title" data-title-es={title} data-title-en={titleEN || title}>{title}</h3>
				<p class="blog-card__desc" data-description-es={contentES} data-description-en={contentEN}>{contentES}</p>
				<span class="blog-card__cta" data-i18n="blog.readMore">Leer mas</span>
			</div>
		</a>
	) : (
		<article class="blog-card">
			<div class="blog-card__media">
				<img alt={title} src={img} loading="lazy" />
			</div>
			<div class="blog-card__body">
				<h3 class="blog-card__title" data-title-es={title} data-title-en={titleEN || title}>{title}</h3>
				<p class="blog-card__desc" data-description-es={contentES} data-description-en={contentEN}>{contentES}</p>
			</div>
		</article>
	)
}

<style>
	.blog-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		max-width: 36rem;
		min-height: 32rem;
		border-radius: 18px;
		overflow: hidden;
		background: linear-gradient(160deg, var(--primary-10), var(--primary-0));
		border: 1px solid color-mix(in srgb, var(--primary-60) 40%, transparent);
		text-decoration: none;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 16px 40px color-mix(in srgb, var(--primary-100) 20%, transparent);
		position: relative;
		isolation: isolate;
	}

	.blog-card::before {
		content: '';
		position: absolute;
		inset: 1px;
		border-radius: 17px;
		background: radial-gradient(
			circle at top,
			color-mix(in srgb, var(--primary-60) 25%, transparent),
			transparent 55%
		);
		opacity: 0.9;
		z-index: -1;
	}

	.blog-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 22px 50px color-mix(in srgb, var(--primary-60) 45%, transparent);
		border-color: color-mix(in srgb, var(--primary-60) 65%, transparent);
	}

	.blog-card__media {
		position: relative;
		width: 100%;
		height: 18rem;
		overflow: hidden;
		background: var(--primary-20);
	}

	.blog-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
		filter: saturate(1.1) brightness(0.92);
	}

	.blog-card:hover .blog-card__media img {
		transform: scale(1.08);
		filter: saturate(1.1) brightness(1.05);
	}

	.blog-card__body {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.blog-card__title {
		font-size: 2.2rem;
		font-weight: 700;
		color: var(--primary-100);
		margin: 0;
		line-height: 1.3;
		transition: all 0.3s ease;
	}

	.blog-card:hover .blog-card__title {
		color: var(--primary-80);
	}

	.blog-card__desc {
		margin: 0;
		font-size: 1.4rem;
		line-height: 1.6;
		color: var(--primary-90);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__cta {
		margin-top: auto;
		font-size: 1.3rem;
		font-weight: 600;
		color: var(--primary-80);
		letter-spacing: 0.02em;
	}

	.blog-card:hover .blog-card__cta {
		color: var(--primary-100);
	}

	@media screen and (max-width: 768px) {
		.blog-card {
			max-width: 100%;
			min-height: 30rem;
		}

		.blog-card__media {
			height: 16rem;
		}
	}
</style>
