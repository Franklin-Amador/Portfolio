---
const { title, img, content, href } = Astro.props;
---
<a href={href} class="blog-card">
	<div class="blog-card__media">
		<img alt={title} src={img} loading="lazy" />
		<div class="blog-card__date">
			<slot name="date" />
		</div>
	</div>
	<div class="blog-card__body">
		<h3 class="blog-card__title">{title}</h3>
		<p class="blog-card__desc">{content}</p>
		<span class="blog-card__cta">Leer mas</span>
	</div>
</a>

<style>
	.blog-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		max-width: 36rem;
		min-height: 32rem;
		border-radius: 18px;
		overflow: hidden;
		background: linear-gradient(145deg, var(--primary-10), var(--primary-0));
		border: 1px solid var(--primary-30);
		text-decoration: none;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
	}

	.blog-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 20px 45px rgba(118, 68, 227, 0.35);
		border-color: var(--primary-60);
	}

	.blog-card__media {
		position: relative;
		width: 100%;
		height: 18rem;
		overflow: hidden;
		background: var(--primary-20);
	}

	.blog-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
		filter: brightness(0.9);
	}

	.blog-card:hover .blog-card__media img {
		transform: scale(1.08);
		filter: brightness(1);
	}

	.blog-card__date {
		position: absolute;
		bottom: 1rem;
		left: 1rem;
		background: var(--card-chip-bg);
		padding: 0.6rem 1rem;
		border-radius: 999px;
		font-size: 1.2rem;
		color: var(--card-chip-text);
		backdrop-filter: blur(6px);
	}

	.blog-card__body {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.blog-card__title {
		font-size: 2rem;
		font-weight: 700;
		color: var(--primary-100);
		margin: 0;
		line-height: 1.3;
		transition: all 0.3s ease;
	}

	.blog-card:hover .blog-card__title {
		background: var(--text-gradient);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.blog-card__desc {
		margin: 0;
		font-size: 1.4rem;
		line-height: 1.6;
		color: var(--primary-90);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__cta {
		margin-top: auto;
		font-size: 1.3rem;
		font-weight: 600;
		color: var(--primary-80);
		letter-spacing: 0.02em;
	}

	.blog-card:hover .blog-card__cta {
		color: var(--primary-100);
	}

	@media screen and (max-width: 768px) {
		.blog-card {
			max-width: 100%;
			min-height: 30rem;
		}

		.blog-card__media {
			height: 16rem;
		}
	}
</style>
