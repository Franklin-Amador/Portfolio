---
import './ThemeToggle.css';

type Props = {
  className?: string;
  label?: string;
};

const { className = '', label } = Astro.props as Props;
const instanceId = `theme-toggle-${Math.random().toString(36).substr(2, 9)}`;
---

<button
  class={`theme-toggle ${className}`.trim()}
  data-theme-toggle
  data-theme-btn={instanceId}
  type="button"
  aria-label="Toggle theme"
  title="Cambiar tema"
>
  <span class="theme-toggle__icon" aria-hidden="true">
    <svg class="theme-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </span>
  {label && (
    <>
      <span class="theme-toggle__text">
        <span class="theme-toggle__label">{label}</span>
        <span class="theme-toggle__mode">Oscuro</span>
      </span>
      <span class="theme-toggle__track" aria-hidden="true">
        <span class="theme-toggle__thumb" />
      </span>
    </>
  )}
</button>

<script is:inline define:vars={{ instanceId }}>
  const btn = document.querySelector(`[data-theme-btn="${instanceId}"]`);
  
  const updateUI = () => {
    const theme = document.documentElement.getAttribute('data-theme') || 'dark';
    const modeText = btn?.querySelector('.theme-toggle__mode');
    const icon = btn?.querySelector('.theme-icon');
    
    if (modeText) modeText.textContent = theme === 'light' ? 'Claro' : 'Oscuro';
    
    if (icon) {
      if (theme === 'dark') {
        icon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
      } else {
        icon.innerHTML = '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
      }
    }
  };

  updateUI();

  btn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'dark';
    const newTheme = current === 'dark' ? 'light' : 'dark';
    
    // Agregar clase de animación al botón
    btn.classList.add('theme-switching');
    
    // Agregar clase de animación al body
    const body = document.body;
    body.classList.add('theme-transitioning');
    
    // Cambiar el tema
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
    updateUI();
    
    // Remover las clases de animación después de que termine
    setTimeout(() => {
      btn.classList.remove('theme-switching');
      body.classList.remove('theme-transitioning');
    }, 300);
  });
</script>
