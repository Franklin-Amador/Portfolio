---
import './hero.css';
import Boton from '../atoms/Boton.astro';
---

<section class="hero">
	<div class="hero__container">
		<div class="text__content">
			<h1 class="hero__title color__gradiente">Franklin Amador</h1>
			<p class="hero__text" data-i18n="hero.subtitle1">
				Full Stack Developer especializado en Data Engineering, Machine Learning y DevOps.
			</p>
			<p class="hero__subtitle" data-i18n="hero.subtitle2">
				Construyo pipelines de datos robustos, modelos ML en producción y arquitecturas cloud escalables.
			</p>
			<div class="hero__buttons">
				<Boton href="#portafolio" texto="Ver Proyectos" bottonI18n="hero.buttonProjects" />
				<Boton href="#contact" texto="Contactar" bottonI18n="hero.buttonContact" />
			</div>
		</div>
		<img 
			class="hero__img" 
			src="/img/foto.jpeg" 
			alt="Franklin Amador - Full Stack & Data Engineer"
			loading="eager"
		/>
	</div>
</section>
