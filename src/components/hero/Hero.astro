---
import './hero.css';
import Boton from '../atoms/Boton.astro';
---

<section class="hero">
	<div class="hero__container">
		<div class="text__content">
			<h1 class="hero__title color__gradiente">Franklin Amador</h1>
			<p class="hero__text">
				Full Stack Developer especializado en crear experiencias web modernas y atractivas.
			</p>
			<p class="hero__subtitle">
				Transformo ideas en aplicaciones web funcionales y elegantes utilizando las últimas tecnologías.
			</p>
			<div class="hero__buttons">
				<Boton href="#portafolio" texto="Ver Proyectos" />
				<Boton href="#contact" texto="Contactar" />
			</div>
		</div>
		<img 
			class="hero__img" 
			src="/img/foto.jpeg" 
			alt="Franklin Amador - Full Stack Developer"
			loading="eager"
		/>
	</div>
</section>
