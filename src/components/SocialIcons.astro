---
const {width, height} = Astro.props;
const socialLinks = [
	{
		title: 'GitHub',
		icon: 'mdi:github',
		href: 'https://github.com/Franklin-Amador',
	},
	{
		title: 'Instagram',
		icon: 'mdi:instagram',
		href: 'https://www.instagram.com/famadorl20',

	},
	{
		title: 'Twitter',
		icon: 'ri:twitter-x-fill',
		href: 'https://x.com/LordFrank37',

	},
	
];
---

<div class="icons__container">
    {
        socialLinks.map((data) => (
            <a
                href={data.href}
                target="_blank"
                rel="nofollow noreferrer noopener"
            >
                <iconify-icon
					class=`skill__icon ${data.title}`
                    icon={data.icon}
                    width={width}
                    height={height}
                />
            </a>
        ))
    }
</div>

<style>
	.icons__container {
		display: flex;
    width: 29.6rem;
    /* padding: 1.3rem 4rem; */
    justify-content: flex-start;
    align-items: flex-start;
    gap: 2rem;
}
.skill__icon{
	color: var(--primary-90);
}

	:global([data-theme="light"]) .skill__icon{
	color: var(--primary-70);
}

	.GitHub:hover{
		color: #ffffff;
	}
	.Instagram:hover{
	color: #E1306C;
	}
	.Twitter:hover{
	color: #0aa5f6;
	}

	:global([data-theme="light"]) .icons__container a:hover .GitHub{
	color: #000000 !important;
}



</style>